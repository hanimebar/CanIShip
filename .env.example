# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BUILDER_PRICE_ID=
STRIPE_STUDIO_PRICE_ID=

# Redis (optional — if not set, falls back to Supabase polling)
REDIS_URL=

# Google PageSpeed Insights API key (optional but recommended for production)
# Without a key: ~100 requests/day — fine for dev/testing
# Free key (no billing): 25,000 requests/day
#   Get one: console.cloud.google.com → Enable "PageSpeed Insights API" → Credentials
# Used as fallback when local Lighthouse cannot run (e.g. memory-constrained containers)
PAGESPEED_API_KEY=

# Docker self-hosted mode
DOCKER_MODE=false
DOCKER_LICENSE_KEY=

# App URL (used for callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook signing secret — used to sign outgoing audit completion webhooks
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=

# Sentry error tracking + performance monitoring
# Get DSN from sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for CI/CD source map uploads — leave blank for local/Docker
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Plausible Analytics — script is hardcoded in app/layout.tsx (no env var needed)
